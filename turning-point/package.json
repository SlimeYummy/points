{
  "name": "turning-point",
  "version": "0.1.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "bin/index.js",
  "engines": {
    "node": ">= 20"
  },
  "napi": {
    "name": "turning-point-node",
    "triples": {
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-linux-android",
        "aarch64-unknown-linux-gnu",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint ./**/*.ts",
    "format": "prettier --write \"./(src|test|demo)/**/*.+(js|ts|json)\"",
    "test": "cross-env INPUT_ASSET=../test-asset OUTPUT_ASSET=../test-tmp/test-asset jest",
    "gen-asset": "cross-env INPUT_ASSET=../test-asset OUTPUT_ASSET=../test-tmp/test-asset ts-node ./test-res/asset.ts",
    "gen-tmpl": "cross-env INPUT_ASSET=../test-asset OUTPUT_ASSET=../test-tmp/test-asset ts-node ./test-res/index.ts",
    "gen-demo": "cross-env INPUT_ASSET=../test-asset OUTPUT_ASSET=../test-tmp/test-asset ts-node ./demo/demo.ts",
    "native-artifacts": "napi artifacts",
    "native-build": "napi build --platform && node build.js",
    "native-release": "napi build --platform --release",
    "native-prepublish": "napi prepublish -t npm",
    "native-universal": "napi universal",
    "native-version": "napi version"
  },
  "devDependencies": {
    "@eslint/js": "^9.39",
    "@jest/globals": "^30.2",
    "@napi-rs/cli": "^3.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0",
    "@types/node": "^25.0",
    "@types/tmp": "^0.2",
    "cross-env": "^10.1",
    "eslint": "^9.19",
    "jest": "^30.2",
    "prettier": "^3.7",
    "ts-jest": "^29.2",
    "ts-node": "^10.9",
    "typescript": "^5.7",
    "typescript-eslint": "^8.46"
  },
  "dependencies": {
    "@formatjs/fast-memoize": "^3.0",
    "art-template": "^4.13",
    "exit-hook": "^5.0",
    "tmp": "^0.2"
  }
}
