{
  "skeleton": {
    "clipped_file": "{{clipped_file}}",
    "renamed_file": "{{prefix}}.{{skeleton_suffix}}-ozz",
    "import": {
      "enable": true,
      "raw": false,
      "types": {
        "skeleton": true,
        "marker": false,
        "camera": false,
        "geometry": false,
        "light": false,
        "null": false,
        "any": false
      }
    }
  },
  "animations": [
    {
      "clip": "Idle",
      "filename": "{{prefix}}_*.{{animation_suffix}}-ozz",
      "raw": false,
      "additive": false,
      "optimize": true
    },
    {
      "clip": "Hit\\d_\\w+",
      "filename": "{{prefix}}_*.{{animation_suffix}}-ozz",
      "raw": false,
      "additive": false,
      "optimize": true,
      "tracks": {
        <% if (root_motion) { %>
        "motion": {
          "enable": true,
          "filename": "{{prefix}}_*.rm-ozz",
          "root_motion_joint": "Root"
        }
        <% } %>
      }
    }
  ]
}
