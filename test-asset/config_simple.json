{
  "skeleton": {
    "clipped_file": "{{clipped_file}}",
    "renamed_file": "{{out_dir}}/{{skeleton_name}}.{{skeleton_suffix}}-ozz",
    "import": {
      "enable": true,
      "types": {
        "skeleton": true
      }
    }
  },
  "animations": [
    {
      "clip": ".*",
      "filename": "{{out_dir}}/*.{{animation_suffix}}-ozz",
      "raw": false,
      "additive": false,
      "optimize": true,
      "tracks": {
        <% if (root_motion) { %>
        "motion": {
            "enable": true,
            "filename": "{{out_dir}}/*.rm-ozz",
            "root_motion_joint": "Root"
          }
        <%
        } %>
      }
    }
  ],
  "json_tracks": [
    <% for(var i = 0; i < json_tracks.length; i++){ %>
      {
        "json": "<%= json_tracks[i].json %>",
        "filename": "<%= json_tracks[i].filename %>"
      }
      <% if (i != json_tracks.length - 1) { %>, <%
      } %>
    <%
    } %>
  ]
}
